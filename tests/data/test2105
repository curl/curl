<?xml version="1.0" encoding="US-ASCII"?>
<testcase>
<info>
<keywords>
HTTP
HSTS
</keywords>
</info>

<client>
<features>
HSTS
</features>
<name>
HSTS save failure leaves the original cache intact
</name>
<command>
--max-time 1 -s -o /dev/null --hsts %LOGDIR/hstsdir%TESTNUMBER/hsts http://127.0.0.1:1/
</command>
<precheck>
%PERL -e 'mkdir "%LOGDIR/hstsdir%TESTNUMBER" or die $!; open(FH, "%GT", "%LOGDIR/hstsdir%TESTNUMBER/hsts") or die $!; print FH "# Your HSTS cache. https://curl.se/docs/hsts.html\n# This file was generated by libcurl! Edit at your own risk.\nexample.com \"29991231 23:59:59\"\n"; close(FH); chmod 0555, "%LOGDIR/hstsdir%TESTNUMBER" or die $!'
</precheck>
</client>

<verify>
<errorcode>
7
</errorcode>
<postcheck>
%PERL -e 'chmod 0755, "%LOGDIR/hstsdir%TESTNUMBER" or die $!; open(FH, "%LT", "%LOGDIR/hstsdir%TESTNUMBER/hsts") or die $!; my $data = do { local $/; %LTFH%GT }; close(FH); $data =~ /example\.com "29991231 23:59:59"/ or die "HSTS cache was clobbered"'
</postcheck>
</verify>
</testcase>
